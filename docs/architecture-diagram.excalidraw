      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "containerId": null,
      "originalText": "NATS Accounts:\n• AUTH — auth-service\n• CHAT — persist-worker,\n         history-service,\n         app users (via callout)\n• SYS  — system account\n\nStream: CHAT_MESSAGES\n  Subjects: chat.*, admin.*",
      "autoResize": true,
      "lineHeight": 1.25
    },

    {
      "id": "roles-note",
      "type": "text",
      "x": 20,
      "y": 540,
      "width": 260,
      "height": 130,
      "text": "Keycloak Role Mapping:\n• admin → pub/sub chat.>, admin.>\n• user  → pub/sub chat.>\n• none  → sub chat.> only\n\nAuth: PKCE (S256)\nRealm: nats-chat\nClient: nats-chat-app",
