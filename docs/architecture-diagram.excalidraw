    {
      "id": "nats-accounts-note",
      "type": "text",
      "x": 20,
      "y": 350,
      "width": 260,
      "height": 160,
      "text": "NATS Accounts:\n• AUTH — auth-service\n• CHAT — persist-worker,\n         history-service,\n         app users (via callout)\n• SYS  — system account\n\nStream: CHAT_MESSAGES\n  Subjects: chat.*, admin.*",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 80,
      "angle": 0,
